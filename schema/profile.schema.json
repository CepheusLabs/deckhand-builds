{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cepheuslabs.com/deckhand/profile.schema.json",
  "title": "Deckhand printer profile",
  "description": "Schema for profile.yaml files under printers/<id>/. Consumed by Deckhand's profile parser.",
  "type": "object",
  "required": ["schema_version", "profile_id", "profile_version", "display_name", "status"],
  "properties": {
    "schema_version": {"type": "integer", "const": 1},
    "profile_id": {"type": "string", "pattern": "^[a-z0-9-]+$"},
    "profile_version": {"type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$"},
    "display_name": {"type": "string", "minLength": 1},
    "manufacturer": {"type": "string"},
    "model": {"type": "string"},
    "status": {
      "type": "string",
      "enum": ["stub", "alpha", "beta", "stable", "deprecated"]
    },
    "maintainers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": {"type": "string"},
          "contact": {"type": "string"}
        }
      }
    },
    "compatible_with": {
      "type": "object",
      "properties": {
        "firmware_variants": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "display_name"],
            "properties": {
              "id": {"type": "string"},
              "display_name": {"type": "string"},
              "notes": {"type": "string"}
            }
          }
        }
      }
    },
    "required_hosts": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Hosts this profile will contact during install. Used for batch approval."
    },
    "identification": {
      "type": "object",
      "description": "Hints the connect screen uses to tell this printer apart from other Moonraker hosts on the LAN. Tiered from strongest to weakest: marker_file > moonraker_objects > hostname_patterns.",
      "properties": {
        "marker_file": {
          "type": "string",
          "description": "Filename under Moonraker's config root (~/printer_data/config/). Deckhand writes this file during install; its presence on the next visit confirms the printer went through our process."
        },
        "moonraker_objects": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Klipper object names that, if any appear in /printer/objects/list, identify this printer model. Matches as prefix-or-exact, so `phrozen_dev` matches `phrozen_dev` or `phrozen_dev:runout`."
        },
        "hostname_patterns": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Regex patterns the Moonraker hostname can match. Surfaced only as a `probable` match because common hostnames (e.g. `mkspi`) are shared across vendor boxes."
        }
      }
    },
    "hardware": {
      "type": "object",
      "properties": {
        "architecture": {"type": ["string", "null"]},
        "sbc": {
          "type": ["object", "null"],
          "properties": {
            "soc": {"type": ["string", "null"]},
            "board": {"type": ["string", "null"]},
            "emmc_size_bytes": {"type": ["integer", "null"]}
          }
        },
        "kinematics": {"type": ["string", "null"]},
        "build_volume_mm": {
          "type": ["object", "null"],
          "properties": {
            "x": {"type": "number"},
            "y": {"type": "number"},
            "z": {"type": "number"}
          }
        },
        "steppers": {"type": "array"},
        "sensors": {"type": "array"},
        "features": {"type": "array", "items": {"type": "string"}}
      }
    },
    "os": {
      "type": "object",
      "properties": {
        "stock": {
          "type": ["object", "null"],
          "properties": {
            "distro": {"type": ["string", "null"]},
            "version": {"type": ["string", "null"]},
            "codename": {"type": ["string", "null"]},
            "python": {"type": ["string", "null"]},
            "notes": {"type": ["string", "null"]}
          }
        },
        "fresh_install_options": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "display_name"],
            "properties": {
              "id": {"type": "string"},
              "display_name": {"type": "string"},
              "url": {"type": "string"},
              "sha256": {"type": ["string", "null"]},
              "size_bytes_approx": {"type": ["integer", "null"]},
              "recommended": {"type": "boolean"},
              "architecture": {"type": "string"},
              "notes": {"type": "string"}
            }
          }
        },
        "boot_mode": {"type": "string", "enum": ["mbr", "gpt"]}
      }
    },
    "ssh": {
      "type": "object",
      "properties": {
        "default_port": {"type": "integer"},
        "default_credentials": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["user"],
            "properties": {
              "user": {"type": "string"},
              "password": {"type": "string"},
              "key_path": {"type": "string"}
            }
          }
        },
        "recommended_user_after_install": {"type": "string"}
      }
    },
    "firmware": {
      "type": "object",
      "properties": {
        "choices": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "display_name", "repo"],
            "properties": {
              "id": {"type": "string"},
              "display_name": {"type": "string"},
              "description": {"type": "string"},
              "repo": {"type": "string", "format": "uri"},
              "ref": {"type": "string"},
              "install_path": {"type": "string"},
              "venv_path": {"type": "string"},
              "python_min": {"type": "string"},
              "recommended": {"type": "boolean"}
            }
          }
        },
        "default_choice": {"type": "string"},
        "replace_stock_in_place": {"type": "boolean"},
        "snapshot_before_replace": {"type": "boolean"},
        "requires_python_rebuild_if": {
          "type": "array",
          "description": "Conditional rules that trigger a Python-from-source rebuild before firmware install. Evaluated in order; first match wins.",
          "items": {
            "type": "object",
            "required": ["condition", "action"],
            "properties": {
              "condition": {
                "type": "string",
                "description": "DSL predicate expression (e.g. 'os_python_below(firmware.selected.python_min)')."
              },
              "action": {
                "type": "string",
                "description": "Machine-readable action tag. Today only 'build-python-from-source' is consumed; additional tags may be added over time."
              },
              "script": {
                "type": "string",
                "description": "Path (repo-relative) to a shell script the Deckhand installer runs over SSH when the condition matches."
              }
            }
          }
        }
      }
    },
    "stack": {
      "type": "object",
      "properties": {
        "moonraker": {"type": "object"},
        "webui": {"type": "object"},
        "kiauh": {"type": "object"},
        "crowsnest": {"type": "object"}
      }
    },
    "mcus": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": {"type": "string"},
          "display_name": {"type": "string"},
          "chip": {"type": "string"},
          "transport": {"type": "object"}
        }
      }
    },
    "screens": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": {"type": "string"},
          "display_name": {"type": "string"},
          "source_kind": {"type": "string"},
          "status": {"type": "string"},
          "recommended": {"type": "boolean"}
        }
      }
    },
    "addons": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": {"type": "string"},
          "kind": {"type": "string"},
          "display_name": {"type": "string"}
        }
      }
    },
    "stock_os": {
      "type": "object",
      "properties": {
        "detections": {"type": "array"},
        "services": {"type": "array"},
        "files": {"type": "array"},
        "paths": {"type": "array"}
      }
    },
    "wizard": {
      "type": "object",
      "properties": {
        "title": {"type": "string"},
        "steps_override": {"type": "object"},
        "extra_steps": {"type": "array"}
      }
    },
    "flows": {
      "type": "object",
      "properties": {
        "stock_keep": {"$ref": "#/$defs/flow_spec"},
        "fresh_flash": {"$ref": "#/$defs/flow_spec"}
      }
    },
    "verifiers": {"type": "array"}
  },
  "$defs": {
    "flow_spec": {
      "type": "object",
      "properties": {
        "enabled": {"type": "boolean"},
        "preconditions": {"type": "array"},
        "steps": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["kind"],
            "properties": {
              "id": {"type": "string"},
              "kind": {"type": "string"}
            },
            "oneOf": [
              {"$ref": "#/$defs/step_write_file"},
              {"$ref": "#/$defs/step_install_marker"},
              {"$ref": "#/$defs/step_script"},
              {"$ref": "#/$defs/step_conditional"},
              {"$ref": "#/$defs/step_generic"}
            ]
          }
        }
      }
    },
    "step_write_file": {
      "type": "object",
      "description": "Destructive-write step. Auto-snapshots the existing target to `<target>.deckhand-pre-<profile-id>-<ts>` (+ `.meta.json` sidecar) before overwriting unless backup=false.",
      "required": ["kind", "target"],
      "properties": {
        "kind": {"const": "write_file"},
        "id": {"type": "string"},
        "target": {
          "type": "string",
          "description": "Absolute path on the printer. Tilde-expansion of `~/...` is resolved against the SSH user's home."
        },
        "template": {
          "type": "string",
          "description": "Repo-relative path to a template file. Rendered through the wizard template engine (double-brace substitutions). Mutually exclusive with `content`."
        },
        "content": {
          "type": "string",
          "description": "Inline content. Mutually exclusive with `template`."
        },
        "sudo": {
          "type": "boolean",
          "description": "Force elevation. When omitted, Deckhand infers sudo for anything outside the SSH user's home or /tmp."
        },
        "mode": {
          "type": ["string", "integer"],
          "description": "Octal permission mode, e.g. \"0644\" or 420."
        },
        "owner": {
          "type": "string",
          "description": "Passed to `sudo install -o <owner>`. No-op without sudo."
        },
        "backup": {
          "type": "boolean",
          "description": "Default true. Set false to skip the auto-snapshot (dangerous)."
        },
        "require_path": {
          "type": "string",
          "description": "Skip the step entirely if this absolute path does not exist on the live printer. Gates profile steps that assume a specific vendor layout (e.g. rewriting KlipperScreen's launcher only when KlipperScreen is installed)."
        }
      }
    },
    "step_install_marker": {
      "type": "object",
      "description": "Writes ~/printer_data/config/deckhand.json so the connect-screen probe can identify this printer next time. Routes through write_file so it inherits auto-backup.",
      "required": ["kind"],
      "properties": {
        "kind": {"const": "install_marker"},
        "id": {"type": "string"},
        "filename": {"type": "string", "default": "deckhand.json"},
        "target_dir": {"type": "string", "description": "Default: ~/printer_data/config"},
        "extra": {"type": "object", "description": "Extra keys to merge into the JSON payload."},
        "backup": {"type": "boolean", "description": "Default true. See step_write_file.backup."}
      }
    },
    "step_script": {
      "type": "object",
      "required": ["kind", "path"],
      "properties": {
        "kind": {"const": "script"},
        "id": {"type": "string"},
        "path": {"type": "string"},
        "interpreter": {"type": "string", "default": "bash"},
        "args": {"type": "array", "items": {"type": "string"}},
        "timeout_seconds": {"type": "integer", "default": 600},
        "ignore_errors": {"type": "boolean"},
        "sudo": {"type": "boolean"},
        "askpass": {"type": "boolean", "default": true}
      }
    },
    "step_conditional": {
      "type": "object",
      "required": ["kind", "when", "then"],
      "properties": {
        "kind": {"const": "conditional"},
        "id": {"type": "string"},
        "when": {
          "type": "string",
          "description": "DSL expression. See docs/DSL.md for predicates."
        },
        "then": {"type": "array"}
      }
    },
    "step_generic": {
      "type": "object",
      "description": "Fallback matcher for step kinds the schema doesn't yet pin down (ssh_commands, snapshot_paths, apply_services, apply_files, install_firmware, install_stack, link_extras, flash_mcus, os_download, flash_disk, wait_for_ssh, verify). These ARE valid; the schema just doesn't constrain their fields.",
      "properties": {
        "kind": {
          "type": "string",
          "not": {"enum": ["write_file", "install_marker", "script", "conditional"]}
        }
      }
    }
  }
}
